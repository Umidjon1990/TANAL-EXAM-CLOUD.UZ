// TANAL Loyihasi — ma'lumotlar bazasi sxemasi
// Prisma + PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Foydalanuvchi rollari ---
enum Role {
  SUPER_ADMIN
  TEST_CENTER_ADMIN
}

// --- Imtihon sanasi statuslari ---
enum ExamStatus {
  PENDING // Tasdiqlash kutilmoqda
  APPROVED // Tasdiqlandi
  REJECTED // Rad etildi
  CANCELLED // Bekor qilindi
  EXPIRED // Muddati o'tgan
}

// --- Telegram post turi ---
enum TelegramPostType {
  EXAM_APPROVED
  NEWS_PUBLISHED
}

// --- Telegram post holati ---
enum TelegramPostStatus {
  SENT
  FAILED
  SKIPPED // Dublikat yoki sozlanmagan
}

// --- Audit log harakat turlari ---
enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  TEST_CENTER_CREATED
  TEST_CENTER_UPDATED
  EXAM_SUBMITTED
  EXAM_APPROVED
  EXAM_REJECTED
  EXAM_CANCELLED
  EXAM_EXPIRED
  NEWS_CREATED
  NEWS_UPDATED
  NEWS_PUBLISHED
  NEWS_DELETED
  TELEGRAM_POST_SENT
  TELEGRAM_POST_FAILED
  LOGIN_SUCCESS
  LOGIN_FAILED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(TEST_CENTER_ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Test markaz admini bitta markazga biriktiriladi
  testCenterId String?
  testCenter   TestCenter? @relation(fields: [testCenterId], references: [id], onDelete: SetNull)

  submittedExams ExamDate[] @relation("SubmittedBy")
  reviewedExams  ExamDate[] @relation("ReviewedBy")
  authoredNews   News[]     @relation("AuthoredNews")
  auditLogs      AuditLog[]

  @@index([role])
  @@index([testCenterId])
}

model TestCenter {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  region    String // Viloyat
  city      String // Shahar / tuman
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admins    User[]
  examDates ExamDate[]

  @@index([region])
  @@index([isActive])
}

model ExamDate {
  id                   String     @id @default(cuid())
  examDate             DateTime // Imtihon sanasi
  registrationDeadline DateTime? // Ro'yxatdan o'tish muddati
  capacity             Int? // Joylar soni
  price                Int? // Narx (so'mda)
  location             String // O'tkaziladigan joy
  description          String?
  status               ExamStatus @default(PENDING)
  rejectReason         String? // Rad etish sababi

  // Telegram idempotentligi — bir marta e'lon qilinadi
  telegramPostedAt DateTime?

  testCenterId String
  testCenter   TestCenter @relation(fields: [testCenterId], references: [id], onDelete: Cascade)

  submittedById String
  submittedBy   User   @relation("SubmittedBy", fields: [submittedById], references: [id])

  reviewedById String?
  reviewedBy   User?     @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  telegramLogs TelegramPostLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([examDate])
  @@index([testCenterId])
  @@index([status, examDate])
}

model News {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String? // Qisqa tavsif
  content     String // To'liq matn
  coverImage  String? // Muqova rasm URL
  published   Boolean   @default(false)
  publishedAt DateTime?

  authorId String
  author   User   @relation("AuthoredNews", fields: [authorId], references: [id])

  telegramLogs TelegramPostLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, publishedAt])
  @@index([authorId])
}

model TelegramPostLog {
  id        String             @id @default(cuid())
  type      TelegramPostType
  status    TelegramPostStatus
  chatId    String?
  messageId Int? // Telegram qaytargan message_id
  error     String?
  createdAt DateTime           @default(now())

  examDateId String?
  examDate   ExamDate? @relation(fields: [examDateId], references: [id], onDelete: SetNull)

  newsId String?
  news   News?   @relation(fields: [newsId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([examDateId])
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  detail    String?
  ipAddress String?
  createdAt DateTime    @default(now())

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
}
